# Dependencies
node_modules/

# Environment files (NEVER commit these)
.env
.env.local
.env.production
backend/.env
automation/.env.test
# Exception: apps/web/.env.production contains only public domain URLs (no secrets).
# Vite bakes VITE_API_URL/VITE_SOCKET_URL into the JS bundle at build time;
# without this file committed, production builds fall back to localhost URLs.
!apps/web/.env.production

# Automation runtime artifacts (generated per-run, contain tokens/secrets)
automation/.test-state.json
automation/reports/

# Build outputs
dist/
build/

# Logs
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
*.pem

# Expo
.expo/
web-build/

# Google Play key (sensitive)
mobile/google-play-key.json
