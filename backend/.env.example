# ──────────────────────────────────────────────────────────────────────────────
# Dine POS — Backend Environment Variables
# Copy this file to .env and fill in every value before starting the server.
# Variables marked REQUIRED will cause the server to exit(1) if missing.
# ──────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development                      # production | staging | development
PORT=5000

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# MongoDB Atlas: Settings → Database → Connect → Drivers → copy connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/dinepos?retryWrites=true&w=majority

# ── Authentication (REQUIRED) ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# Separate secret for super-admin JWTs. Falls back to JWT_SECRET if unset,
# but a distinct value is strongly recommended so hotel and super-admin tokens
# cannot be cross-used even if one secret leaks.
SUPER_ADMIN_JWT_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET

# ── Super Admin (REQUIRED) ────────────────────────────────────────────────────
SUPER_ADMIN_ID=your_superadmin_username
SUPER_ADMIN_PASS=your_superadmin_password

# ── CORS (REQUIRED in production) ────────────────────────────────────────────
# Comma-separated list of all frontend origins that may call the API.
# Example for production:
ALLOWED_ORIGINS=https://app.dinepos.com,https://qr.dinepos.com,https://admin.dinepos.com,https://www.dinepos.com
# For local dev (leave blank to allow all):
# ALLOWED_ORIGINS=

# WebSocket CSP origin (REQUIRED in production) ── restricts connectSrc to this host.
# Without it the CSP falls back to wss:/ws: (any domain). Set to the API host.
SOCKET_ORIGIN=wss://api.dinepos.com
# Leave unset in local dev.

# ── Redis (REQUIRED when running >1 backend instance) ────────────────────────
# Upstash Redis: create a database → copy REST URL (ioredis format).
# Without this, Socket.IO uses in-memory adapter — safe for 1 instance only.
# Omit entirely for local development (app runs without Redis).
REDIS_URL=rediss://:<password>@<host>.upstash.io:6379

# ── Image Uploads (REQUIRED for product image uploads) ───────────────────────
# Cloudinary: Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Aggregator Webhook (REQUIRED if aggregator feature is enabled) ────────────
# Shared secret sent by Swiggy/Zomato webhook integrations in X-Aggregator-Secret header.
AGGREGATOR_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Lead Email Alerts (REQUIRED for lead notification emails to super admin) ──
# SMTP credentials used by emailService.ts to send new-lead alert emails.
# Recommended: create a transactional email account (SendGrid, Brevo, Postmark)
# and configure it to relay through their SMTP gateway.
# Example (Gmail SMTP — not recommended for production volume):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=<app-password>       # Google App Password, not your login password
# Example (SendGrid):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=465
#   SMTP_USER=apikey
#   SMTP_PASS=SG.<your-api-key>
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=noreply@example.com
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
# Email address that receives new-lead alert emails from the contact/demo forms.
LEAD_ALERT_EMAIL=sales@example.com

# ── Error Tracking (optional but strongly recommended for production) ─────────
# Sentry: https://sentry.io → Projects → DSN
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# ── Log Aggregation (optional but strongly recommended for production) ────────
# Better Stack (Logtail): https://logs.betterstack.com → Sources → Source Token
LOGTAIL_SOURCE_TOKEN=your_logtail_token
