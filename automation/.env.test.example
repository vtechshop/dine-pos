# ── API Configuration ─────────────────────────────────────────────────────────
# Base URL of the running backend API (no trailing slash)
TEST_API_URL=http://localhost:5000

# ── Super Admin Credentials ───────────────────────────────────────────────────
# These match SUPER_ADMIN_ID and SUPER_ADMIN_PASS in the backend .env
SUPER_ADMIN_ID=superadmin
SUPER_ADMIN_PASS=super1234

# ── JWT Configuration ─────────────────────────────────────────────────────────
# Must match JWT_SECRET in the backend .env
JWT_SECRET=hotelbillingpos_secret_key_change_in_production

# ── MongoDB (for direct DB access in setup/teardown) ─────────────────────────
# Use a SEPARATE test database — never point at production
MONGODB_TEST_URI=mongodb://localhost:27017/dinepos_test

# ── Socket Configuration ──────────────────────────────────────────────────────
SOCKET_URL=http://localhost:5000

# ── Web (Playwright) ─────────────────────────────────────────────────────────
# Base URL of the web frontend (if applicable)
WEB_BASE_URL=http://localhost:3000

# QR Menu public base URL
QR_BASE_URL=http://localhost:5000/api/public

# ── Performance (k6) ─────────────────────────────────────────────────────────
K6_CLOUD_TOKEN=

# ── Security (OWASP ZAP) ─────────────────────────────────────────────────────
ZAP_API_KEY=your-zap-api-key
ZAP_HOST=localhost
ZAP_PORT=8080

# ── Test Timeouts (ms) ───────────────────────────────────────────────────────
DEFAULT_TIMEOUT=10000
SOCKET_TIMEOUT=8000
PERFORMANCE_TIMEOUT=60000

# ── CI Environment ────────────────────────────────────────────────────────────
# Set to true in GitHub Actions / CI environment
CI=false
HEADLESS=true
