{
  "name": "@dine-pos/automation",
  "version": "1.0.0",
  "private": true,
  "description": "Complete automation testing framework for Dine POS multi-tenant SaaS",
  "scripts": {
    "test:api": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests' --forceExit --detectOpenHandles",
    "test:api:auth": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/auth' --forceExit",
    "test:api:orders": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/orders' --forceExit",
    "test:api:menu": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/menu' --forceExit",
    "test:api:reports": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/reports' --forceExit",
    "test:api:settings": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/settings' --forceExit",
    "test:api:notifications": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/notifications' --forceExit",
    "test:api:security": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/security' --forceExit",
    "test:api:multitenant": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests/multitenant' --forceExit",
    "test:api:coverage": "cross-env NODE_ENV=test jest --config jest.config.ts --testPathPattern='api/tests' --coverage --coverageReporters=html --coverageReporters=lcov --coverageReporters=text --forceExit",
    "test:web": "playwright test --config web/playwright.config.ts",
    "test:web:headed": "playwright test --config web/playwright.config.ts --headed",
    "test:web:debug": "playwright test --config web/playwright.config.ts --debug",
    "test:web:report": "playwright show-report reports/playwright-html",
    "test:mobile": "maestro test mobile/flows/ --config mobile/config.yaml",
    "test:mobile:registration": "maestro test mobile/flows/01-registration.yaml",
    "test:mobile:admin-login": "maestro test mobile/flows/02-admin-login.yaml",
    "test:mobile:kitchen-login": "maestro test mobile/flows/03-kitchen-login.yaml",
    "test:mobile:waiter-login": "maestro test mobile/flows/04-waiter-login.yaml",
    "test:mobile:cashier-login": "maestro test mobile/flows/05-cashier-login.yaml",
    "test:mobile:create-order": "maestro test mobile/flows/06-create-order.yaml",
    "test:mobile:kitchen-flow": "maestro test mobile/flows/07-kitchen-accept-order.yaml",
    "test:mobile:waiter-flow": "maestro test mobile/flows/08-waiter-serve-order.yaml",
    "test:mobile:cashier-flow": "maestro test mobile/flows/09-cashier-complete-order.yaml",
    "test:mobile:qr": "maestro test mobile/flows/10-qr-menu-order.yaml",
    "test:performance:smoke": "k6 run performance/k6/smoke-test.js -e API_URL=$TEST_API_URL -e ADMIN_ID=$ADMIN_ID -e ADMIN_PASSWORD=$ADMIN_PASSWORD",
    "test:performance:load100": "k6 run performance/k6/load-100.js -e API_URL=$TEST_API_URL -e ADMIN_ID=$ADMIN_ID -e ADMIN_PASSWORD=$ADMIN_PASSWORD -e HOTEL_ID=$HOTEL_ID",
    "test:performance:load500": "k6 run performance/k6/load-500.js -e API_URL=$TEST_API_URL -e ADMIN_ID=$ADMIN_ID -e ADMIN_PASSWORD=$ADMIN_PASSWORD -e HOTEL_ID=$HOTEL_ID",
    "test:performance:stress1000": "k6 run performance/k6/stress-1000.js -e API_URL=$TEST_API_URL -e ADMIN_ID=$ADMIN_ID -e ADMIN_PASSWORD=$ADMIN_PASSWORD -e HOTEL_ID=$HOTEL_ID",
    "test:performance:socket": "k6 run performance/k6/socket-100.js -e SOCKET_URL=$SOCKET_URL -e ADMIN_TOKEN=$ADMIN_TOKEN -e HOTEL_ID=$HOTEL_ID",
    "test:performance:qr": "k6 run performance/k6/qr-concurrent.js -e API_URL=$TEST_API_URL -e HOTEL_ID=$HOTEL_ID",
    "test:performance:orders10k": "k6 run performance/k6/orders-10k.js -e API_URL=$TEST_API_URL -e ADMIN_ID=$ADMIN_ID -e ADMIN_PASSWORD=$ADMIN_PASSWORD",
    "test:performance:spike": "k6 run performance/k6/spike-test.js -e API_URL=$TEST_API_URL -e ADMIN_ID=$ADMIN_ID -e ADMIN_PASSWORD=$ADMIN_PASSWORD -e HOTEL_ID=$HOTEL_ID",
    "test:security": "bash security/zap/run-zap.sh",
    "test:all": "bash scripts/run-all.sh",
    "install:playwright": "playwright install chromium firefox webkit",
    "install:all": "npm install && npm run install:playwright",
    "lint": "eslint . --ext .ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "report:open": "open reports/html/index.html || xdg-open reports/html/index.html || start reports/html/index.html"
  },
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "axios": "^1.7.2",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.7.0",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}
